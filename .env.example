# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Base de datos (Railway la inyecta automáticamente) ────────────────────────
DATABASE_URL=postgresql://usuario:password@host:5432/medicore

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── reCAPTCHA v2 (verificación de "No soy un robot" en /auth/register) ─────────
# En no-producción, si se deja vacío se usa la test key pública de Google
# (verificación siempre pasa). En PRODUCCIÓN es OBLIGATORIA: sin ella el
# backend no arranca. Obtener la real en https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET=

# ── Cifrado en reposo de datos sensibles (AES-256-GCM) ────────────────────────
# Llave de 32 bytes. Generar con: openssl rand -base64 32
# ⚠️ NO cambiar ni perder esta llave: los datos cifrados quedarían irrecuperables.
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend en Vercel. Lista separada por comas para múltiples orígenes.
CORS_ORIGIN=https://medicore.vercel.app

# ── Archivos subidos ──────────────────────────────────────────────────────────
# En Railway: montar un volume en /data y apuntar aquí
UPLOAD_PATH=/data/uploads
MAX_FILE_SIZE=20971520

# ── Email (Resend — API HTTP, puerto 443) ────────────────────────────────────
# Railway bloquea SMTP saliente; se usa la API HTTP de Resend.
# API key en https://resend.com/api-keys . Si falta, los correos se registran
# en log pero NO se envían (la app arranca igual, con warning).
RESEND_API_KEY=
# Remitente: DEBE ser una dirección de un dominio verificado en Resend,
# si no, Resend rechaza el envío (se registra el error).
MAIL_FROM=Medicore <no-reply@medicore.app>

# ── Zona horaria para cron jobs ───────────────────────────────────────────────
APP_TIMEZONE=America/Santiago

