# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Base de datos (Railway la inyecta automáticamente) ────────────────────────
DATABASE_URL=postgresql://usuario:password@host:5432/medicore

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── reCAPTCHA v2 (verificación de "No soy un robot" en /auth/register) ─────────
# En no-producción, si se deja vacío se usa la test key pública de Google
# (verificación siempre pasa). En PRODUCCIÓN es OBLIGATORIA: sin ella el
# backend no arranca. Obtener la real en https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET=

# ── Cifrado en reposo de datos sensibles (AES-256-GCM) ────────────────────────
# Llave de 32 bytes. Generar con: openssl rand -base64 32
# ⚠️ NO cambiar ni perder esta llave: los datos cifrados quedarían irrecuperables.
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend en Vercel. Lista separada por comas para múltiples orígenes.
CORS_ORIGIN=https://medicore.vercel.app

# URL pública de la app para enlaces de cara al usuario (p. ej. el link de
# aceptación de invitación familiar del correo). OPCIONAL: si se omite, se usa
# el PRIMER origen de CORS_ORIGIN. Útil cuando CORS_ORIGIN lista varios orígenes.
# APP_URL=https://medi-history.com

# ── Archivos subidos ──────────────────────────────────────────────────────────
# En Railway: montar un volume en /data y apuntar aquí
UPLOAD_PATH=/data/uploads
MAX_FILE_SIZE=20971520

# ── Email (Resend — API HTTP, puerto 443) ────────────────────────────────────
# Railway bloquea SMTP saliente; se usa la API HTTP de Resend.
# API key en https://resend.com/api-keys . Si falta, los correos se registran
# en log pero NO se envían (la app arranca igual, con warning).
RESEND_API_KEY=
# Remitente: DEBE ser una dirección de un dominio verificado en Resend,
# si no, Resend rechaza el envío (se registra el error).
MAIL_FROM=Medicore <no-reply@medicore.app>

# ── Zona horaria para cron jobs ───────────────────────────────────────────────
APP_TIMEZONE=America/Santiago

# ── Pagos recurrentes (MercadoPago — planes Pro/Family) ─────────────────────────
# Reemplaza la integración anterior con Flow.cl (Flow exige empresa
# constituida para Cargo Automático; el usuario opera como persona natural).
# Checkout con tokenización de tarjeta (Checkout Bricks): el frontend
# (medicore-frontend) embebe el componente <CardPayment> de
# @mercadopago/sdk-react, que tokeniza la tarjeta del lado del cliente dentro
# de un iframe seguro de MercadoPago (el número/CVV nunca tocan nuestro
# backend ni se guardan en la BD). El frontend envía ese card_token_id a
# POST /payments/checkout; el backend llama SÍNCRONAMENTE a
# POST /preapproval con card_token_id + status:'authorized' y activa el plan
# directo con la respuesta (ver
# specs/mercadopago-checkout-bricks-tarjeta/design.md). Ya NO es un checkout
# 100% redirect a un init_point externo.
#
# Token de acceso de la aplicación (dashboard de MercadoPago). NO existe un
# host de sandbox separado: la MISMA https://api.mercadopago.com sirve test y
# producción — se distinguen solo por el TIPO de credencial usada (token de
# una "cuenta de prueba" vs. token de producción, ambos creados en el
# dashboard). Si falta, /payments/checkout, /payments/webhook (verificación de
# firma) y /payments/subscription/cancel responden 503 de forma controlada; el
# resto de la app (incluido /payments/subscription en modo "sin suscripción")
# arranca y funciona igual — mismo patrón que RESEND_API_KEY/Flow.
MERCADOPAGO_ACCESS_TOKEN=
# Clave secreta del webhook, sección "Webhooks" de la aplicación en el
# dashboard de MercadoPago. Se usa para validar el header `x-signature` de
# cada notificación ANTES de procesar el body. La URL de notificaciones
# (${API_PUBLIC_URL o dominio público}/payments/webhook) se configura ahí
# también, de forma manual — no existe un campo `notification_url` en el body
# de la API de suscripciones.
MERCADOPAGO_WEBHOOK_SECRET=
# No hace falta crear ningún `preapproval_plan` en el dashboard de
# MercadoPago: el checkout crea suscripciones "sin plan asociado"
# (POST /preapproval sin preapproval_plan_id, CON card_token_id +
# status: 'authorized'). El monto y la razón de cada plan (pro/family) están
# hardcodeados en
# payments.service.ts, sincronizados manualmente con
# medicore-frontend/src/utils/plans.ts (única fuente de verdad de los
# precios visibles al usuario) — si el precio cambia, hay que actualizar
# ambos archivos.

